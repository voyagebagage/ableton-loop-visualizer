{
	"name": "loop-view",
	"version": "0.1.0",
	"type": "module",
	"description": "Ableton Loop Visualizer — Loopy Pro-style circular loop ring visualizations for Ableton Live session clips via AbletonOSC",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"dev:web": "vite",
		"hmr": "vite --port 5173",
		"build": "vite build",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"electrobun": "1.16.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"concurrently": "^9.1.0",
		"solid-js": "^1.9.3",
		"typescript": "^5.7.2",
		"vite": "^6.0.3",
		"vite-plugin-solid": "^2.11.0"
	}
}
